# Environment Variables for UptimeMonitoring
# Copy this file to .env and update the values

# Database Configuration
POSTGRES_DB=uptime_monitoring
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Connection Strings
DB_CONNECTION_STRING=Host=host.docker.internal;Port=5432;Database=uptime_monitoring;Username=uptime;Password=your_secure_password_here

# Redis Configuration
REDIS_CONNECTION=localhost:6379
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-for-local-dev-only-32chars
JWT_ISSUER=UptimeMonitoring
JWT_AUDIENCE=UptimeMonitoringUsers
JWT_EXPIRY_MINUTES=60

# Email Configuration (Optional)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=alerts@example.com

# Port Configuration (Optional)
API_PORT=8080
POSTGRES_PORT=5000
